# Database configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5435/hxstu_db?schema=public"

# NestJS Server Configuration
PORT=3001

# Auth Secrets
JWT_SECRET="super-secret-key-change-in-production"

# ============================================================================
# AI Provider (chuẩn OpenAI-compatible). Đổi provider CHỈ bằng các biến dưới đây,
# không cần sửa code. Không hard-code API key/model/base URL trong source.
# ----------------------------------------------------------------------------
# AI_PROVIDER: "openai-compatible" (mặc định) hoặc "fallback" (không gọi AI,
#   chạy hoàn toàn bằng rule/database).
AI_PROVIDER="openai-compatible"

# Endpoint tương thích OpenAI (KHÔNG kèm /chat/completions, code tự thêm).
#   OpenAI     : https://api.openai.com/v1
#   OpenRouter : https://openrouter.ai/api/v1
#   Proxy/GW   : https://your-proxy-domain.com/v1
#   Ollama     : http://localhost:11434/v1  (AI_API_KEY để "ollama")
AI_BASE_URL="https://api.openai.com/v1"
AI_API_KEY=""
AI_MODEL="gpt-4o-mini"

AI_TIMEOUT_MS="30000"
AI_MAX_RETRIES="2"
# Giới hạn token đầu ra. Model reasoning (vd deepseek-v4-flash) tiêu token cho
# phần "nghĩ" nên cần headroom lớn; để thấp có thể trả content rỗng. Mặc định 2000.
AI_MAX_TOKENS="2000"
# Bật fallback khi AI lỗi/hết quota (401/403/429/404/5xx/timeout). Mặc định "true".
# Khi bật: tìm kiếm/tạo học viên/ghi danh xử lý bằng database TRƯỚC (không phụ
# thuộc LLM); nếu LLM lỗi ở câu mơ hồ thì vẫn tìm trực tiếp trong DB.
AI_ENABLE_FALLBACK="true"

# ----------------------------------------------------------------------------
# (LEGACY / OPTIONAL) Gemini & Groq KHÔNG còn được dùng mặc định. Giữ lại chỉ để
# tham khảo; hệ thống hiện chạy qua AI Provider Adapter ở trên.
# OPENAI_API_KEY=""
# GEMINI_API_KEY=""
# GROQ_API_KEY=""

# Copilot Agent
# true  -> chỉ expose tool bản mini (tạo học viên, tạo khóa, tạo lớp, ghi danh học viên vào khóa)
# false -> expose full tool
AGENT_MINI_MODE="true"
# Tự đóng session ACTIVE cũ hơn số giờ này khi bootstrap (theo updatedAt)
COPILOT_SESSION_TTL_HOURS="24"
# (Tùy chọn) true -> giữ tiền tố "LOP_" khi sinh classCode; false/không đặt ->
# bỏ tiền tố "lớp" ở đầu tên khi sinh mã lớp (mặc định).
CLASS_CODE_KEEP_LOP_PREFIX="false"

# Frontend URL for CORS
FRONTEND_URL="http://localhost:3000"
